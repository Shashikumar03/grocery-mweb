# Postman: set grocery_base_url = https://grocery-app-env.up.railway.app
# then GET {{grocery_base_url}}/api/category/all
#
# --- Recommended for `npm run dev` / `npm run preview` (same-origin + Vite proxy, no CORS issues)
# VITE_API_BASE_URL=
#
# --- Do NOT set on Netlify if you use _redirects proxy (causes 401/CORS). Leave unset or empty.
# VITE_API_BASE_URL=https://grocery-app-env.up.railway.app
#
# Razorpay Checkout — key ID only (safe in the browser). Never put the secret here.
# Local/preview: rzp_test_...  |  Netlify production: rzp_live_...
# Use the SAME key_id as React Native + Railway backend (must match order creation keys)
# VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
#
# Netlify: Site settings → Environment variables → add VITE_RAZORPAY_KEY_ID, then redeploy.
# razorpay_secret_key belongs on your backend (Railway), not in this frontend app.
#
# Razorpay Dashboard → Webhooks → URL (server only, not called from browser):
# https://grocery-app-env.up.railway.app/api/webhook
# Events: payment.captured, payment.failed (match your Spring controller)
#
# Production site (Netlify) — required for AdSense / contact page
# VITE_SITE_URL=https://bazzari.netlify.app
# VITE_SITE_NAME=Bazzari
# VITE_CONTACT_EMAIL=shashikumarkushwaha1@gmail.com
# VITE_CONTACT_PHONE=+91XXXXXXXXXX
#
# Google AdSense — create a display ad unit in AdSense, copy the data-ad-slot value:
# VITE_ADSENSE_SLOT=1234567890
# Optional: VITE_ADSENSE_ENABLED=false to hide ad units in dev
#
# IPL prediction promo — leave unset (off) during AdSense review; set true after approval:
# VITE_ENABLE_IPL_PROMO=true
