# Postman: set grocery_base_url = https://grocery-app-env.up.railway.app
# then GET {{grocery_base_url}}/api/category/all
#
# --- Recommended for `npm run dev` / `npm run preview` (same-origin + Vite proxy, no CORS issues)
# VITE_API_BASE_URL=
#
# --- Do NOT set on Netlify if you use _redirects proxy (causes 401/CORS). Leave unset or empty.
# VITE_API_BASE_URL=https://grocery-app-env.up.railway.app
#
# Razorpay Checkout — key ID only (safe in the browser). Never put the secret here.
# Local/preview: rzp_test_...  |  Netlify production: rzp_live_...
# Use the SAME key_id as your React Native app + Railway backend (e.g. rzp_live_UDn0...)
# VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
#
# Netlify: Site settings → Environment variables → add VITE_RAZORPAY_KEY_ID, then redeploy.
# razorpay_secret_key belongs on your backend (Railway), not in this frontend app.
